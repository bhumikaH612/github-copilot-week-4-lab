{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Account Management System",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/src/accounting/index.js",
      "restart": true,
      "console": "integratedTerminal",
